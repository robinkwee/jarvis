# GeniBot — Environment Configuration
# For the GENAIO.org project

# Brain Configuration
GENAIO_BRAIN_PATH=./brain
# Point to your GENAIO project brain directory
# Example: /home/robin/SecondBrain/GENAIO (shared) or dedicated brain

# Agent Settings
AGENT_NAME=GeniBot
AGENT_ROLE=genaio-project

# Logging
LOG_LEVEL=info
# Options: debug, info, warn, error

# Port Configuration
PORT=8003
# Maps to localhost:8003 locally
# On VPS, reverse proxy (Nginx) routes traffic

# Integrations (Optional)
GOOGLE_WORKSPACE_ENABLED=false
# Set to true when connecting Google Workspace MCPs for:
# - Shared project docs (Google Docs)
# - Project calendar (Google Calendar)
# - Shared Drive (project files)

GITHUB_ENABLED=true
# For syncing project docs to GitHub repo (genaio-app, GENAIO)

# Resources
MEMORY_LIMIT=1g
CPU_LIMIT=0.5
